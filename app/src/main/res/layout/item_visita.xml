<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: item_visita.xml
    Responsabilidad: Define la estructura visual de un elemento individual (fila) dentro del listado de visitas.
    Estructura: Utiliza un CardView para proporcionar elevación y bordes redondeados, mejorando la separación
    visual entre registros. Organiza la información mediante una combinación de RelativeLayout y LinearLayouts
    anidados para una disposición clara de textos e imágenes.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    card_view:cardCornerRadius="10dp"
    card_view:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- Evidencia Fotográfica: Miniatura del comercio capturado -->
        <ImageView
            android:id="@+id/imgFoto"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:contentDescription="@string/foto_comercio"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <!-- Contenedor de Información Textual -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgFoto"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="0dp">

            <!-- Bloque de Título: Índice y Nombre Comercial -->
            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtNumero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:text="@string/number_1"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtNombreComercial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="0dp"
                    android:layout_weight="1"
                    android:text="@string/nombre_comercial"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Datos Secundarios del Registro -->
            <TextView
                android:id="@+id/txtCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cliente" />

            <TextView
                android:id="@+id/txtTelefono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/telefono" />

            <TextView
                android:id="@+id/txtDiaVisita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dia_visita" />

            <!-- Representación de coordenadas geográficas -->
            <TextView
                android:id="@+id/txtCoordenadas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lat_lng" />

        </LinearLayout>

        <!-- Acceso al Menú Contextual (Overflow) -->
        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:contentDescription="@string/opciones_de_visita"
            android:src="@drawable/ic_more_vert" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>