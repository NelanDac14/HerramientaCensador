<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:padding="16dp">

    <!-- 🔷 TÍTULO -->
    <TextView
        android:id="@+id/txtTituloSeguimiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/seguimiento"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/toolbarColor"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 🔷 CARD CLIENTE -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCliente"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloSeguimiento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp">

            <TextView
                android:text="@string/cliente"
                android:textStyle="bold"
                android:textColor="#6B7280"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <TextView
                android:id="@+id/txtClienteReferencia"
                android:text="@string/nombre_cliente"
                android:textSize="16sp"
                android:layout_marginTop="5dp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 🔷 SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardCliente"
        app:layout_constraintBottom_toTopOf="@id/btnGuardarSeguimiento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 📸 FOTO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/evidencia_fotografica"
                        android:textStyle="bold"
                        android:layout_height="16dp"
                        android:layout_width="wrap_content"/>

                    <ImageView
                        android:id="@+id/imgFotoSeguimiento"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="centerCrop"
                        android:background="#E5E7EB"/>

                    <Button
                        android:id="@+id/btnTomarFotoSeguimiento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/tomar_foto"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 📊 ESTADO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/estado_de_venta"
                        android:textStyle="bold"
                        android:layout_height="16dp"
                        android:layout_width="wrap_content"/>

                    <Spinner
                        android:id="@+id/spinEstadoVenta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:entries="@array/opcSiNo"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 📝 COMENTARIOS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/comentarios"
                        android:textStyle="bold"
                        android:layout_height="16dp"
                        android:layout_width="wrap_content"/>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtComentarios"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/observaciones_del_seguimiento"
                        android:minHeight="80dp"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- 🔥 BOTÓN -->
    <Button
        android:id="@+id/btnGuardarSeguimiento"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/registrar_seguimiento"
        android:layout_marginTop="12dp"
        android:backgroundTint="#006F84"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>