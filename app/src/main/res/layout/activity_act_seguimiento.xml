<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_act_seguimiento.xml
    Responsabilidad: Interfaz para el registro de eventos de seguimiento (bitácora).
    Propósito: Recolectar datos dinámicos de una nueva visita sin redundar en la información maestra del cliente.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Encabezado Informativo: Referencia del Cliente -->
    <TextView
        android:id="@+id/txtTituloSeguimiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/titulo_seguimiento"
        android:textColor="#006F84"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtClienteReferencia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/datos_cliente"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloSeguimiento" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnGuardarSeguimiento"
        app:layout_constraintTop_toBottomOf="@id/txtClienteReferencia">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Captura de Evidencia Fotográfica Actual -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/titFotoNegocio"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgFotoSeguimiento"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:background="@android:color/darker_gray"
                android:scaleType="centerCrop" />

            <Button
                android:id="@+id/btnTomarFotoSeguimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#006F84"
                android:text="@string/tomar_foto_del_comercio" />

            <!-- Estado de la Gestión Comercial -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/titVenta"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinEstadoVenta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/spinner_primary"
                android:entries="@array/opcSiNo"
                android:minHeight="48dp" />

            <!-- Bitácora de Observaciones -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/comentarios"
                app:boxStrokeColor="#006F84">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtComentariosSeguimiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:lines="4" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Acción: Finalizar Seguimiento -->
    <Button
        android:id="@+id/btnGuardarSeguimiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#006F84"
        android:text="@string/btnGuardar"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>